---
import type { BlogEntry } from '../lib/posts';
import { formatDate } from '../lib/posts';

const { post } = Astro.props as { post: BlogEntry };
---

<article class="rounded-card border border-base-300 bg-base-100 p-6 shadow-lg shadow-base-300/20">
	<div class="flex flex-wrap items-center gap-2 text-sm text-base-content/65">
		<span class="badge badge-outline">{post.data.category}</span>
		<span class="whitespace-nowrap">{formatDate(post.data.publishDate)}</span>
	</div>
	<h3 class="mt-4 text-xl font-semibold tracking-tight sm:text-2xl">
		<a class="hover:text-primary" href={`/stories/${post.id}/`}>{post.data.title}</a>
	</h3>
	<p class="mt-3 leading-8 text-base-content/75">{post.data.description}</p>
	<div class="mt-6">
		<a class="btn btn-link px-0 text-primary" href={`/stories/${post.id}/`}>Read story</a>
	</div>
</article>
