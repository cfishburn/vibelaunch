---
import { pageTitle, site } from '../config/site';
import Layout from '../layouts/Layout.astro';

interface Props {
	eyebrow?: string;
	title: string;
	description?: string;
	metaTitle?: string;
}

const { eyebrow = site.name, title, description, metaTitle = title } = Astro.props as Props;

const hasActions = Astro.slots.has('actions');
---

<Layout title={pageTitle(metaTitle)} description={description}>
	<section class="mx-auto max-w-5xl px-6 py-16 lg:py-20">
		<div class="rounded-card-lg border border-base-300 bg-base-100 p-8 shadow-xl shadow-base-300/15">
			<div class="max-w-3xl space-y-4">
				<p class="eyebrow">{eyebrow}</p>
				<h1 class="text-5xl font-semibold tracking-tight text-balance">{title}</h1>
				{description ? <p class="text-lg leading-8 text-base-content/75">{description}</p> : null}
				{hasActions ? (
					<div class="flex flex-wrap gap-3 pt-2">
						<slot name="actions" />
					</div>
				) : null}
			</div>
		</div>
		<div class="mt-8">
			<slot />
		</div>
	</section>
</Layout>
