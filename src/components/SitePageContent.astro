---
import type { AstroComponentFactory } from 'astro/runtime/server/index.js';

interface Props {
	Content: AstroComponentFactory;
	useContentFlow?: boolean;
	class?: string;
}

const { Content: ContentComponent, useContentFlow = true, class: className } = Astro.props as Props;
---

{useContentFlow ? (
	<article class:list={['content-flow', className]}>
		<ContentComponent />
	</article>
) : (
	<ContentComponent />
)}
