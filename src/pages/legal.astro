---
import PageTemplate from '../components/PageTemplate.astro';
import SitePageContent from '../components/SitePageContent.astro';
import { getSitePage } from '../lib/site-pages';

const { Content, entry } = await getSitePage('legal');
---

<PageTemplate
	eyebrow={entry.data.eyebrow}
	title={entry.data.title}
	description={entry.data.description}
	metaTitle={entry.data.metaTitle}
>
	<SitePageContent Content={Content} useContentFlow={entry.data.useContentFlow} class="mt-8" />
</PageTemplate>
