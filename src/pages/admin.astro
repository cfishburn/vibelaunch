---
export const prerender = false;

import AdminPanel from '../components/AdminPanel';
import PageTemplate from '../components/PageTemplate.astro';
import { getSitePage } from '../lib/site-pages';

const { Content, entry } = await getSitePage('admin');
---

<PageTemplate
	eyebrow={entry.data.eyebrow}
	title={entry.data.title}
	description={entry.data.description}
	metaTitle={entry.data.metaTitle}
>
	<div slot="actions">
		{entry.data.actions.map((action) => (
			<a
				class:list={[
					'btn',
					action.variant === 'primary' && 'btn-primary',
					action.variant === 'outline' && 'btn-outline',
					action.variant === 'ghost' && 'btn-ghost',
				]}
				href={action.href}
			>
				{action.label}
			</a>
		))}
	</div>

	{entry.data.useContentFlow ? (
		<article class="content-flow mb-8">
			<Content />
		</article>
	) : (
		<Content />
	)}

	<AdminPanel client:load />
</PageTemplate>
