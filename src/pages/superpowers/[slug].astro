---
import { type CollectionEntry, getCollection, render } from 'astro:content';
import { pageTitle } from '../../config/site';
import Layout from '../../layouts/Layout.astro';
import {
	getSuperpowerRoute,
	getSuperpowerSummary,
	sortSuperpowers,
} from '../../lib/superpower-docs';

export async function getStaticPaths() {
	const docs = await getCollection('superpowers');

	return docs.map((doc) => ({
		params: { slug: doc.id },
		props: { doc },
	}));
}

const { doc } = Astro.props as { doc: CollectionEntry<'superpowers'> };
const { Content } = await render(doc);
const libraryDocs = sortSuperpowers(await getCollection('superpowers'));
const updatedAt =
	doc.data.date ?? (doc.data.last_updated ? new Date(String(doc.data.last_updated)) : null);
const documentType = String(doc.data.type ?? doc.data.doc_type ?? 'guide');
const summary = getSuperpowerSummary(doc.id);
const siblingDocs = libraryDocs.filter((entry) => entry.id !== doc.id);
---

<Layout
	title={pageTitle(doc.data.title)}
	description={summary}
	type="article"
	publishDate={updatedAt ?? undefined}
	author={doc.data.author}
>
	<section class="mx-auto max-w-6xl px-6 py-16 lg:py-20">
		<div class="rounded-card-lg border border-base-300 bg-base-100 p-8 shadow-xl shadow-base-300/15 lg:p-10">
			<div class="max-w-3xl">
				<p class="eyebrow">Documentation superpower</p>
				<div class="mt-4 flex flex-wrap items-center gap-3 text-sm text-base-content/60">
					<span class="badge badge-outline">{documentType}</span>
					{updatedAt ? <span>Updated {updatedAt.toISOString().split('T')[0]}</span> : null}
					{doc.data.author ? <span>By {doc.data.author}</span> : null}
				</div>
				<h1 class="mt-6 text-4xl font-semibold tracking-tight text-balance lg:text-5xl">
					{doc.data.title}
				</h1>
				<p class="mt-4 text-lg leading-8 text-base-content/72">{summary}</p>
				<div class="mt-6 flex flex-wrap gap-3">
					<a class="btn btn-primary" href="/superpowers">
						Back to docs library
					</a>
					<a class="btn btn-outline" href="/how-to-scaffold-an-agentic-coding-project">
						Back to playbook
					</a>
					<a class="btn btn-ghost" href="/">Back home</a>
				</div>
			</div>
		</div>

		<div class="mt-10 grid gap-8 lg:grid-cols-[minmax(0,1fr)_18rem] xl:grid-cols-[minmax(0,1fr)_20rem]">
			<article class="min-w-0 rounded-card-lg border border-base-300 bg-base-100 p-7 shadow-lg shadow-base-300/15 lg:p-10">
				<div class="superpower-prose content-flow">
					<Content />
				</div>
			</article>

			<aside class="space-y-4 lg:sticky lg:top-6 lg:self-start">
				<div class="rounded-card border border-base-300 bg-base-100 p-5 shadow-lg shadow-base-300/15">
					<p class="eyebrow">In this library</p>
					<div class="mt-4 space-y-3">
						{libraryDocs.map((entry) => (
							<a
								class:list={[
									'block rounded-box border p-4 transition',
									entry.id === doc.id
										? 'border-primary/40 bg-primary/8'
										: 'border-base-300 bg-base-100 hover:border-primary/30 hover:bg-base-200/50',
								]}
								href={getSuperpowerRoute(entry.id)}
							>
								<span class="block font-semibold text-base-content">{entry.data.title}</span>
								<span class="mt-1 block text-sm leading-6 text-base-content/65">
									{getSuperpowerSummary(entry.id)}
								</span>
							</a>
						))}
					</div>
				</div>

				{doc.data.supersedes ? (
					<div class="rounded-card border border-base-300 bg-base-100 p-5 shadow-lg shadow-base-300/15">
						<p class="eyebrow">Supersedes</p>
						<p class="mt-3 text-sm leading-7 text-base-content/72">{String(doc.data.supersedes)}</p>
					</div>
				) : null}

				{siblingDocs.length > 0 ? (
					<div class="rounded-card border border-base-300 bg-base-100 p-5 shadow-lg shadow-base-300/15">
						<p class="eyebrow">Read next</p>
						<div class="mt-4 space-y-3">
							{siblingDocs.map((entry) => (
								<a class="block text-sm leading-7 text-primary underline-offset-4 hover:underline" href={getSuperpowerRoute(entry.id)}>
									{entry.data.title}
								</a>
							))}
						</div>
					</div>
				) : null}
			</aside>
		</div>
	</section>
</Layout>
