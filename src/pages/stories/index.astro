---
import { pageTitle, site } from '../../config/site';
import Layout from '../../layouts/Layout.astro';
import { formatDate, getAllPosts } from '../../lib/posts';

const posts = await getAllPosts();
---

<Layout
	title={pageTitle('Stories')}
	description="Field notes from taking AI-assisted prototypes and turning them into codebases people can actually live with."
>
	<section class="mx-auto max-w-5xl px-6 py-16 lg:py-20">
		<div class="max-w-3xl space-y-4">
			<p class="eyebrow">{site.stories.indexEyebrow}</p>
			<h1 class="text-5xl font-semibold tracking-tight text-balance">{site.stories.indexTitle}</h1>
			<p class="text-lg leading-8 text-base-content/75">{site.stories.indexDescription}</p>
		</div>

		<div class="mt-10 grid gap-4">
			{posts.map((post) => (
				<a
					href={`/stories/${post.id}/`}
					class="motion-lift rounded-3xl border border-base-300 bg-base-100 p-6 hover:border-primary/30 hover:shadow-lg hover:shadow-base-300/20"
					data-reveal="vertical"
				>
					<div class="flex flex-col gap-4 md:flex-row md:items-start md:justify-between md:gap-6">
						<div class="min-w-0 flex-1 space-y-3">
							<div class="flex flex-wrap items-center gap-2 text-sm text-base-content/60">
								<span class="badge badge-outline">{post.data.category}</span>
								<span>{formatDate(post.data.publishDate)}</span>
							</div>
							<h2 class="text-2xl font-semibold tracking-tight">{post.data.title}</h2>
							<p class="leading-8 text-base-content/75">{post.data.description}</p>
						</div>
						<span class="shrink-0 whitespace-nowrap text-sm font-medium text-primary">{site.stories.openLabel}</span>
					</div>
				</a>
			))}
		</div>
	</section>
</Layout>
