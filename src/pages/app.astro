---
export const prerender = false;

import PageTemplate from '../components/PageTemplate.astro';
import ViewerPanel from '../components/ViewerPanel';
import { isAdminUserId } from '../lib/auth';
import { getSitePage } from '../lib/site-pages';

const { userId } = Astro.locals.auth();
const isAdmin = isAdminUserId(userId);
const { Content, entry } = await getSitePage('app');
---

<PageTemplate
	eyebrow={entry.data.eyebrow}
	title={entry.data.title}
	description={entry.data.description}
	metaTitle={entry.data.metaTitle}
>
	<div slot="actions">
		{entry.data.actions.map((action) => (
			<a
				class:list={[
					'btn',
					action.variant === 'primary' && 'btn-primary',
					action.variant === 'outline' && 'btn-outline',
					action.variant === 'ghost' && 'btn-ghost',
				]}
				href={action.href}
			>
				{action.label}
			</a>
		))}
		{isAdmin ? <a class="btn btn-outline" href="/admin">Open admin page</a> : null}
	</div>

	{entry.data.useContentFlow ? (
		<article class="content-flow mb-8">
			<Content />
		</article>
	) : (
		<Content />
	)}

	<ViewerPanel client:load />
</PageTemplate>
