---
export const prerender = false;

import { Icon, ShieldCheckIcon } from '../components/icons';
import PageActions from '../components/PageActions.astro';
import PageTemplate from '../components/PageTemplate.astro';
import SitePageContent from '../components/SitePageContent.astro';
import ViewerPanel from '../components/ViewerPanel';
import { isAdminUserId } from '../lib/auth';
import { getSitePage } from '../lib/site-pages';

const { userId } = Astro.locals.auth();
const isAdmin = isAdminUserId(userId);
const { Content, entry } = await getSitePage('app');
---

<PageTemplate
	eyebrow={entry.data.eyebrow}
	title={entry.data.title}
	description={entry.data.description}
	metaTitle={entry.data.metaTitle}
>
	<PageActions slot="actions" actions={entry.data.actions}>
		{isAdmin ? (
			<a class="btn btn-outline gap-2" href="/admin">
				<Icon icon={ShieldCheckIcon} className="h-4 w-4" />
				Open admin page
			</a>
		) : null}
	</PageActions>
	<SitePageContent Content={Content} useContentFlow={entry.data.useContentFlow} class="mb-8" />

	<ViewerPanel client:load />
</PageTemplate>
